# ============================================================================
# Local Life Asia — mẫu biến môi trường. Copy sang .env.local và điền giá trị.
# Chi tiết kiến trúc lưu trữ: docs/storage.md
# ============================================================================

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...
# Model routing
ANTHROPIC_MODEL_CHAT=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
# Voyage for embeddings (mạnh tiếng Việt)
VOYAGE_API_KEY=pa-...

# --- Auth (Google Workspace SSO) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                 # openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=locallife.asia

# --- Storage ---
# Postgres: audit log + BM25 index cache (không phải source of truth)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/locallife
# Qdrant: vector index (rebuild được từ knowledge/*.md)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Text tier (3-way replication, xem docs/storage.md §2) ---
# Tier 2: Local server — runtime read path cho chatbot
# Dev: trỏ tới knowledge/ trong repo; prod: /var/locallife/kb
KNOWLEDGE_DIR=./knowledge

# Tier 1: GitHub (source of truth)
KNOWLEDGE_REPO_OWNER=huytdvn
KNOWLEDGE_REPO_NAME=locallife-knowledge
KNOWLEDGE_REPO_BRANCH=main
GITHUB_TOKEN=                    # fine-grained PAT, ghi vào knowledge repo
KNOWLEDGE_WEBHOOK_SECRET=        # HMAC cho /webhook/knowledge-merged

# Tier 3: Cloudflare R2 (object-locked, versioned archive)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_RAW=locallife-raw
R2_BUCKET_KB_ARCHIVE=locallife-kb-archive
R2_OBJECT_LOCK_YEARS_RESTRICTED=10
R2_OBJECT_LOCK_YEARS_INTERNAL=3
R2_OBJECT_LOCK_YEARS_PUBLIC=1

# --- Raw tier (2-way replication, xem docs/storage.md §3) ---
# Tier 1: Local server ZFS volume
RAW_DIR=/mnt/locallife-raw
LEGAL_DIR=/mnt/locallife-legal

# Tier 2: Google Drive (service account)
GOOGLE_DRIVE_RAW_FOLDER_ID=
GOOGLE_DRIVE_LEGAL_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=./google-service-account.json

# --- Queue ---
REDIS_URL=redis://localhost:6379

# --- Ingest service ---
INGEST_API_URL=http://localhost:8001
INGEST_API_TOKEN=                # shared secret giữa web ↔ ingest
