{
  "name": "locallife-asia",
  "private": true,
  "version": "0.0.0",
  "description": "Local Life Asia — website công khai và hệ thống nội bộ AI-native",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "typecheck": "pnpm --filter web typecheck",
    "ingest:dev": "cd apps/ingest && uvicorn app.main:app --reload --port 8001",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down"
  }
}
